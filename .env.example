# ── Gemini API ───────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=pubmed
POSTGRES_PASSWORD=pubmed
POSTGRES_DB=pubmed_pipeline
DATABASE_URL=postgresql://pubmed:pubmed@localhost:5432/pubmed_pipeline

# ── PubMed FTP ────────────────────────────────────────────────
# Base URL for PubMed annual baseline files
PUBMED_FTP_BASE_URL=https://ftp.ncbi.nlm.nih.gov/pubmed/baseline
# Local directory to store downloaded .xml.gz files
PUBMED_DATA_DIR=/app/data/pubmed

# ── Pipeline config ───────────────────────────────────────────
# Target abstract count (stop downloading after filtering yields this many)
TARGET_ABSTRACT_COUNT=5000
# Max abstracts per LLM batch call
LLM_BATCH_SIZE=16
# Gemini model to use
GEMINI_MODEL=gemini/gemini-1.5-flash

# ── Dagster ───────────────────────────────────────────────────
DAGSTER_POSTGRES_USER=pubmed
DAGSTER_POSTGRES_PASSWORD=pubmed
DAGSTER_POSTGRES_DB=pubmed_pipeline
DAGSTER_POSTGRES_HOST=localhost
DAGSTER_POSTGRES_PORT=5432
