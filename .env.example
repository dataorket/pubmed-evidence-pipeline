# ── Gemini API ───────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini/gemini-flash-latest
LLM_BATCH_SIZE=8

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=pubmed
POSTGRES_PASSWORD=pubmed
POSTGRES_DB=pubmed_pipeline
DATABASE_URL=postgresql://pubmed:pubmed@localhost:5432/pubmed_pipeline

# ── PubMed FTP ────────────────────────────────────────────────
PUBMED_FTP_BASE_URL=https://ftp.ncbi.nlm.nih.gov/pubmed/baseline
PUBMED_DATA_DIR=/app/data/pubmed

# ── Dagster ───────────────────────────────────────────────────
# Set DAGSTER_HOME to the absolute path of the repo root (local dev only)
DAGSTER_HOME=/path/to/your/repo
DAGSTER_POSTGRES_USER=pubmed
DAGSTER_POSTGRES_PASSWORD=pubmed
DAGSTER_POSTGRES_DB=pubmed_pipeline
DAGSTER_POSTGRES_HOST=localhost
DAGSTER_POSTGRES_PORT=5432

# ── Partition range (controls which PubMed files are seeded on Docker startup) ─
PARTITION_START=1200
PARTITION_END=1209
